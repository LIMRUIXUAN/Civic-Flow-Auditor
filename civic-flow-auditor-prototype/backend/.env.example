HOST=127.0.0.1
PORT=8787
CORS_ORIGIN=http://127.0.0.1:5173
DATABASE_URL=sqlite:///./.audit-runs/audits-python.sqlite
REDIS_URL=redis://127.0.0.1:6379/0
AUDIT_STORAGE_DIR=.audit-runs
MAX_PAGES=10
MAX_CONCURRENT_AUDITS=1
AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
TEXT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AI_TIMEOUT_MS=12000
ENABLE_OCR=1
ENABLE_LIGHTHOUSE=0
CELERY_TASK_ALWAYS_EAGER=0