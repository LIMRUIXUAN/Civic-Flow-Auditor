HOST=127.0.0.1
PORT=8787
AUDIT_STORAGE_DIR=.audit-runs
AUDIT_DATABASE_PATH=.audit-runs/audits.sqlite
MAX_PAGES=10
MAX_CONCURRENT_AUDITS=1
CORS_ORIGIN=http://127.0.0.1:5173

AI_PROVIDER=openrouter
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/free
VISION_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
TEXT_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
AI_TIMEOUT_MS=12000

ENABLE_LIGHTHOUSE=0
ENABLE_OCR=1
SERVE_STATIC_DIST=0
