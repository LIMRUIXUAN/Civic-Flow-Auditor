HOST=127.0.0.1
PORT=8787
AUDIT_STORAGE_DIR=.audit-runs
AUDIT_DATABASE_PATH=.audit-runs/audits.sqlite
MAX_PAGES=10
MAX_CONCURRENT_AUDITS=1
CORS_ORIGIN=http://127.0.0.1:5173

# AI provider: "google" (Gemini via Google ADK) or "none" for deterministic-only.
AI_PROVIDER=google
# Get a key from https://aistudio.google.com/apikey (GEMINI_API_KEY also accepted).
GOOGLE_API_KEY=
VISION_MODEL=gemini-2.0-flash
TEXT_MODEL=gemini-2.0-flash
AI_TIMEOUT_MS=20000

ENABLE_LIGHTHOUSE=0
ENABLE_OCR=1
SERVE_STATIC_DIST=0
